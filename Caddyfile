# /etc/caddy/Caddyfile — serves the web app at the root and proxies the API.
toolcut.net {
    encode gzip

    # API endpoints go to the FastAPI backend
    @api path /health /process /jobs /model
    handle @api {
        request_body {
            max_size 25MB
        }
        reverse_proxy 127.0.0.1:8000
    }

    # Everything else serves the web app
    handle {
        root * /var/www/toolcut
        try_files {path} /index.html
        file_server
    }
}
