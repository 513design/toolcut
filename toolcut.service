# /etc/systemd/system/toolcut.service
[Unit]
Description=toolcut FastAPI service
After=network.target

[Service]
Type=simple
User=toolcut
WorkingDirectory=/opt/toolcut
EnvironmentFile=/opt/toolcut/.env
ExecStart=/opt/toolcut/venv/bin/uvicorn server:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3
NoNewPrivileges=true
ProtectSystem=full
PrivateTmp=true

[Install]
WantedBy=multi-user.target
