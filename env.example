# Copy to /opt/toolcut/.env and fill in. Loaded by the systemd unit.
# Everything lives in Supabase now — no AWS / S3 needed.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
SUPABASE_BUCKET=cutouts

# Only if your Supabase project still uses legacy HS256 signing keys:
# SUPABASE_JWT_SECRET=your-legacy-jwt-secret

# 0 = unlimited. Set e.g. 50 for a free-tier monthly cap per user.
MONTHLY_QUOTA=0
